# Required: Your Groq API key (free at console.groq.com)
GROQ_API_KEY=your-groq-key-here

# Optional: Directory where ChromaDB stores its data (default: ./chroma_db)
CHROMA_PERSIST_DIR=./chroma_db

# Optional: Number of words per text chunk (default: 500)
CHUNK_SIZE=500

# Optional: Word overlap between adjacent chunks (default: 50)
CHUNK_OVERLAP=50

# Optional: Number of top chunks retrieved per query (default: 4)
TOP_K=4
